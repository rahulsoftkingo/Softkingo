generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ChatConversation {
  id           Int           @id @default(autoincrement())
  visitorId    String
  visitorName  String?
  visitorEmail String?
  visitorPhone String?
  status       String        @default("active")
  priority     String        @default("normal")
  assignedToId Int?
  tags         String?
  notes        String?
  rating       Int?
  feedback     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  closedAt     DateTime?
  assignedTo   User?         @relation("ChatAssignedTo", fields: [assignedToId], references: [id], map: "ChatConversation_assignedToId_fkey")
  messages     ChatMessage[]

  @@index([assignedToId], map: "ChatConversation_assignedToId_fkey")
  @@map("chatconversation")
}

model ChatMessage {
  id             Int              @id @default(autoincrement())
  conversationId Int
  content        String           @db.Text
  sender         String
  senderName     String?
  type           String           @default("text")
  fileUrl        String?
  fileName       String?
  isRead         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade, map: "ChatMessage_conversationId_fkey")

  @@index([conversationId], map: "ChatMessage_conversationId_fkey")
  @@map("chatmessage")
}

model User {
  id               Int                @id @default(autoincrement())
  name             String?
  email            String?            @unique(map: "User_email_key")
  username         String             @unique(map: "User_username_key")
  passwordHash     String
  status           String             @default("active")
  profileImage     String?
  phone            String?
  whatsapp         String?
  title            String?
  department       String?
  bio              String?
  lastLoginAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  lastClockIn      DateTime?
  lastClockOut     DateTime?
  profileImageType String?
  adminLogs        AdminLog[]
  attendances      Attendance[]       @relation("UserAttendances")
  blogPosts        BlogPost[]
  chatsAssigned    ChatConversation[] @relation("ChatAssignedTo")
  contentItems     ContentItem[]
  employeeSalary   EmployeeSalary?    @relation("UserEmployeeSalary")
  leadsOwned       Lead[]             @relation("LeadOwner")
  LeadActivity     LeadActivity[]
  leaveApprovals   LeaveRequest[]     @relation("LeaveApprovals")
  leaveRequests    LeaveRequest[]     @relation("UserLeaveRequests")
  MediaItem        MediaItem[]
  pages            Page[]
  // payslips         Payslip[]          @relation("UserPayslips")
  ticketsOwned     Ticket[]           @relation("TicketOwner")
  ticketsRequested Ticket[]           @relation("TicketRequester")
  ticketComments   TicketComment[]
  roles            UserRole[]

  @@map("user")
}

model Role {
  id           Int              @id @default(autoincrement())
  name         String           @unique(map: "Role_name_key")
  displayName  String
  description  String?
  defaultRoute String?
  permissions  RolePermission[]
  users        UserRole[]

  @@map("role")
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  roleId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "UserRole_roleId_fkey")
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade, map: "UserRole_userId_fkey")

  @@unique([userId, roleId], map: "UserRole_userId_roleId_key")
  @@index([roleId], map: "UserRole_roleId_fkey")
  @@map("userrole")
}

model Permission {
  id          Int              @id @default(autoincrement())
  key         String           @unique(map: "Permission_key_key")
  module      String?
  description String?
  roles       RolePermission[]

  @@map("permission")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, map: "RolePermission_permissionId_fkey")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "RolePermission_roleId_fkey")

  @@unique([roleId, permissionId], map: "RolePermission_roleId_permissionId_key")
  @@index([permissionId], map: "RolePermission_permissionId_fkey")
  @@map("rolepermission")
}

model BlogCategory {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique(map: "BlogCategory_slug_key")
  createdAt DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  posts          BlogPost[]
  seoTitle       String?
  seoDescription String?
  seoImage       String?

  @@map("blogcategory")
}

model BlogTag {
  id    Int           @id @default(autoincrement())
  name           String
  slug           String        @unique(map: "BlogTag_slug_key")
  posts          BlogPostTag[]
  seoTitle       String?
  seoDescription String?
  seoImage       String?

  @@map("blogtag")
}

model BlogPostTag {
  postId Int
  tagId  Int
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade, map: "BlogPostTag_postId_fkey")
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade, map: "BlogPostTag_tagId_fkey")

  @@id([postId, tagId])
  @@index([tagId], map: "BlogPostTag_tagId_fkey")
  @@map("blogposttag")
}

model BlogPost {
  id              Int            @id @default(autoincrement())
  type            String         @default("blog")
  placements      String?        @db.Text
  title           String
  slug            String         @unique(map: "BlogPost_slug_key")
  excerpt         String?
  contentJson     String?        @db.LongText
  status          String         @default("draft")
  featured        Boolean        @default(false)
  pinned          Boolean        @default(false)
  thumbnail       String?
  heroImage       String?
  readTimeMinutes Int?
  seoTitle        String?
  seoDescription  String?
  seoImage        String?
  publishedAt     DateTime?
  scheduledFor    DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  authorId        Int?
  categoryId      Int?
  likeCount       Int            @default(0)
  shareCount      Int            @default(0)
  viewCount       Int            @default(0)
  thumbnailType   String?
  feedbacks       BlogFeedback[]
  author          User?          @relation(fields: [authorId], references: [id], map: "BlogPost_authorId_fkey")
  category        BlogCategory?  @relation(fields: [categoryId], references: [id], map: "BlogPost_categoryId_fkey")
  tags            BlogPostTag[]

  @@index([authorId], map: "BlogPost_authorId_fkey")
  @@index([categoryId], map: "BlogPost_categoryId_fkey")
  @@map("blogpost")
}

model BlogFeedback {
  id        Int      @id @default(autoincrement())
  postId    Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade, map: "BlogFeedback_postId_fkey")

  @@index([postId], map: "BlogFeedback_postId_fkey")
  @@map("blogfeedback")
}

model EGuide {
  id             Int       @id @default(autoincrement())
  slug           String    @unique(map: "EGuide_slug_key")
  title          String
  authorName     String?
  authorRole     String?
  coverImage     String?
  category       String?
  description    String?
  readTimeText   String?
  summary        String?
  sectionsJson   String?   @db.LongText
  pdfUrl         String?
  status         String    @default("draft")
  publishedAt    DateTime?
  seoTitle       String?
  seoDescription String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  downloadCount  Int       @default(0)

  @@map("eguide")
}

model ContentItem {
  id             Int       @id @default(autoincrement())
  type           String
  title          String
  slug           String    @unique(map: "ContentItem_slug_key")
  excerpt        String?
  contentJson    String?
  industry       String?
  country        String?
  clientName     String?
  featured       Boolean   @default(false)
  thumbnail      String?
  heroImage      String?
  seoTitle       String?
  seoDescription String?
  status         String    @default("draft")
  publishedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  authorId       Int?
  downloadCount  Int       @default(0)
  author         User?     @relation(fields: [authorId], references: [id], map: "ContentItem_authorId_fkey")

  @@index([authorId], map: "ContentItem_authorId_fkey")
  @@map("contentitem")
}

model PortfolioProject {
  id          Int        @id @default(autoincrement())
  key         String     @unique(map: "PortfolioProject_key_key")
  type        String
  title       String
  category    String?
  description String?
  techStack   String?
  platforms   String?
  country     String?
  bgImage     String?
  bgColor     String?
  icon        String?
  phoneMockup String?
  badgesJson  String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  caseStudyId Int?
  caseStudy   CaseStudy? @relation(fields: [caseStudyId], references: [id], map: "PortfolioProject_caseStudyId_fkey")

  @@index([caseStudyId], map: "PortfolioProject_caseStudyId_fkey")
  @@map("portfolioproject")
}

model CaseStudy {
  id                Int                @id @default(autoincrement())
  slug              String             @unique(map: "CaseStudy_slug_key")
  title             String
  subtitle          String?
  logo              String?
  heroBgImage       String?
  heroCircle        String?
  heroMockups       String?            @db.Text
  brandingJson      String?            @db.Text
  teamJson          String?            @db.Text
  clientJson        String?            @db.Text
  technologiesJson  String?            @db.Text
  overviewJson      String?            @db.Text
  requirementsJson  String?            @db.Text
  goalsJson         String?            @db.Text
  challengesJson    String?            @db.Text
  appScreensJson    String?            @db.LongText
  resultsJson       String?            @db.Text
  findYourAppJson   String?            @db.Text
  seoTitle          String?
  seoDescription    String?
  seoImage          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  portfolioProjects PortfolioProject[]

  @@map("casestudy")
}

model Page {
  id             Int              @id @default(autoincrement())
  key            String
  title          String
  slug           String           @unique(map: "Page_slug_key")
  type           String
  excerpt        String?          @db.LongText
  contentJson    String?          @db.LongText
  heroImage      String?
  status         String           @default("draft")
  featured       Boolean          @default(false)
  seoTitle       String?
  seoDescription String?          @db.LongText
  seoImage       String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  authorId       Int?
  navItems       NavigationItem[]
  author         User?            @relation(fields: [authorId], references: [id], map: "Page_authorId_fkey")

  @@index([authorId], map: "Page_authorId_fkey")
  @@index([slug], map: "Page_slug_idx")
  @@index([type, status], map: "Page_type_status_idx")
  @@map("page")
}

model NavigationItem {
  id      Int     @id @default(autoincrement())
  label   String
  href    String
  group   String?
  order   Int     @default(0)
  visible Boolean @default(true)
  pageId  Int?
  page    Page?   @relation(fields: [pageId], references: [id], map: "NavigationItem_pageId_fkey")

  @@index([pageId], map: "NavigationItem_pageId_fkey")
  @@map("navigationitem")
}

model TeamMember {
  id          Int      @id @default(autoincrement())
  name        String
  title       String?
  department  String?
  photo       String?
  bio         String?
  linkedinUrl String?
  order       Int      @default(0)
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // New optional fields - won't affect existing data
  category       String?  // employee, management, tech-lead, intern
  status         String?  // active, inactive, alumni
  seoTitle       String?
  seoDescription String?
  seoImage       String?

  @@map("teammember")
}

model EmployeeDirectoryItem {
  id         Int      @id @default(autoincrement())
  name       String
  title      String?
  department String?
  photo      String?
  email      String?
  phone      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("employeedirectoryitem")
}

model MediaItem {
  id           Int      @id @default(autoincrement())
  title        String?
  filePath     String
  thumbnail    String?
  type         String
  category     String?
  tags         String?
  createdAt    DateTime @default(now())
  uploadedById Int?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], map: "MediaItem_uploadedById_fkey")

  @@index([uploadedById], map: "MediaItem_uploadedById_fkey")
  @@map("mediaitem")
}

model SiteEvent {
  id                   Int       @id @default(autoincrement())
  title                String
  message              String
  ctaLabel             String?
  ctaHref              String?
  status               String    @default("draft")
  startsAt             DateTime?
  endsAt               DateTime?
  theme                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  maxShowsPerUser      Int?
  showOnSlugs          String?
  triggerDelayMs       Int?
  triggerScrollPercent Int?
  imageUrl             String?

  @@map("siteevent")
}

model Lead {
  id             Int            @id @default(autoincrement())
  name           String
  email          String
  phone          String?
  whatsapp       String?
  source         String?
  campaign       String?
  message        String?
  status         String         @default("new")
  tags           String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  ownerId        Int?
  formKey        String?
  formType       String?
  utmCampaign    String?
  utmMedium      String?
  utmSource      String?
  attachmentName String?
  budgetLabel    String?
  ndaAccepted    Boolean?
  owner          User?          @relation("LeadOwner", fields: [ownerId], references: [id], map: "Lead_ownerId_fkey")
  activities     LeadActivity[]
  tickets        Ticket[]

  @@index([ownerId], map: "Lead_ownerId_fkey")
  @@map("lead")
}

model LeadActivity {
  id          Int      @id @default(autoincrement())
  leadId      Int
  type        String
  content     String?
  createdAt   DateTime @default(now())
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id], map: "LeadActivity_createdById_fkey")
  lead        Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade, map: "LeadActivity_leadId_fkey")

  @@index([createdById], map: "LeadActivity_createdById_fkey")
  @@index([leadId], map: "LeadActivity_leadId_fkey")
  @@map("leadactivity")
}

model Ticket {
  id          Int             @id @default(autoincrement())
  status      String          @default("open")
  priority    String          @default("medium")
  channel     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  description String?
  dueDate     DateTime?
  leadId      Int?
  ownerId     Int?
  requesterId Int?
  resolvedAt  DateTime?
  tags        String?
  title       String
  lead        Lead?           @relation(fields: [leadId], references: [id], map: "Ticket_leadId_fkey")
  owner       User?           @relation("TicketOwner", fields: [ownerId], references: [id], map: "Ticket_ownerId_fkey")
  requester   User?           @relation("TicketRequester", fields: [requesterId], references: [id], map: "Ticket_requesterId_fkey")
  comments    TicketComment[]

  @@index([leadId], map: "Ticket_leadId_fkey")
  @@index([ownerId], map: "Ticket_ownerId_fkey")
  @@index([requesterId], map: "Ticket_requesterId_fkey")
  @@map("ticket")
}

model TicketComment {
  id          Int      @id @default(autoincrement())
  ticketId    Int
  type        String   @default("note")
  visibility  String   @default("internal")
  content     String
  createdAt   DateTime @default(now())
  createdById Int?
  createdBy   User?    @relation(fields: [createdById], references: [id], map: "TicketComment_createdById_fkey")
  ticket      Ticket   @relation(fields: [ticketId], references: [id], onDelete: NoAction, map: "TicketComment_ticketId_fkey")

  @@index([createdById], map: "TicketComment_createdById_fkey")
  @@index([ticketId], map: "TicketComment_ticketId_fkey")
  @@map("ticketcomment")
}

model NewsletterList {
  id          Int                      @id @default(autoincrement())
  name        String
  slug        String                   @unique(map: "NewsletterList_slug_key")
  description String?
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  campaigns   EmailCampaign[]
  subscribers NewsletterSubscription[]

  @@map("newsletterlist")
}

model NewsletterSubscription {
  id             Int               @id @default(autoincrement())
  email          String
  name           String?
  whatsapp       String?
  status         String            @default("active")
  source         String?
  subscribedAt   DateTime          @default(now())
  unsubscribedAt DateTime?
  listId         Int
  events         NewsletterEvent[]
  list           NewsletterList    @relation(fields: [listId], references: [id], onDelete: Cascade, map: "NewsletterSubscription_listId_fkey")

  @@unique([email, listId], map: "NewsletterSubscription_email_listId_key")
  @@index([listId], map: "NewsletterSubscription_listId_fkey")
  @@map("newslettersubscription")
}

model NewsletterEvent {
  id             Int                    @id @default(autoincrement())
  type           String
  metaJson       String?
  createdAt      DateTime               @default(now())
  subscriptionId Int
  subscription   NewsletterSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade, map: "NewsletterEvent_subscriptionId_fkey")

  @@index([subscriptionId], map: "NewsletterEvent_subscriptionId_fkey")
  @@map("newsletterevent")
}

model EmailCampaign {
  id           Int                @id @default(autoincrement())
  name         String
  subject      String
  preheader    String?
  slug         String             @unique(map: "EmailCampaign_slug_key")
  status       String             @default("draft")
  contentHtml  String?
  contentText  String?
  providerId   String?
  scheduledFor DateTime?
  sentAt       DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  listId       Int
  list         NewsletterList     @relation(fields: [listId], references: [id], onDelete: Cascade, map: "EmailCampaign_listId_fkey")
  logs         EmailDeliveryLog[]

  @@index([listId], map: "EmailCampaign_listId_fkey")
  @@map("emailcampaign")
}

model EmailDeliveryLog {
  id         Int           @id @default(autoincrement())
  email      String
  event      String
  providerId String?
  metaJson   String?
  createdAt  DateTime      @default(now())
  campaignId Int
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade, map: "EmailDeliveryLog_campaignId_fkey")

  @@index([campaignId], map: "EmailDeliveryLog_campaignId_fkey")
  @@map("emaildeliverylog")
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique(map: "EmailTemplate_slug_key")
  subject   String
  preview   String?
  bodyHtml  String?  @db.LongText
  bodyText  String?
  category  String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("emailtemplate")
}

model WhatsappIntegration {
  id          Int      @id @default(autoincrement())
  provider    String
  phoneNumber String
  name        String?
  status      String   @default("active")
  configJson  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("whatsappintegration")
}

model WhatsappTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  category  String?
  body      String   @db.LongText
  language  String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("whatsapptemplate")
}

model AdminLog {
  id                Int      @id @default(autoincrement())
  userId            Int?
  action            String
  entityType        String
  entityId          Int?
  payloadBeforeJson String?
  payloadAfterJson  String?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime @default(now())
  user              User?    @relation(fields: [userId], references: [id], map: "AdminLog_userId_fkey")

  @@index([userId], map: "AdminLog_userId_fkey")
  @@map("adminlog")
}

model Attendance {
  id        Int               @id @default(autoincrement())
  userId    Int
  clockIn   DateTime          @default(now())
  clockOut  DateTime?
  duration  Int?
  location  String?
  notes     String?
  status    String            @default("active")
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User              @relation("UserAttendances", fields: [userId], references: [id], onDelete: Cascade)
  breaks    AttendanceBreak[]

  @@index([userId])
  @@index([clockIn])
  @@map("attendance")
}

model AttendanceBreak {
  id           Int        @id @default(autoincrement())
  attendanceId Int
  startTime    DateTime   @default(now())
  endTime      DateTime?
  duration     Int?
  notes        String?
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([attendanceId])
  @@map("attendance_break")
}

model LeaveRequest {
  id         Int      @id @default(autoincrement())
  userId     Int
  type       String
  startDate  DateTime
  endDate    DateTime
  duration   Float
  reason     String?
  status     String   @default("pending")
  approvedBy Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  approver   User?    @relation("LeaveApprovals", fields: [approvedBy], references: [id])
  user       User     @relation("UserLeaveRequests", fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([approvedBy], map: "leave_request_approvedBy_fkey")
  @@map("leave_request")
}

model EmployeeSalary {
  id         Int       @id @default(autoincrement())
  userId     Int       @unique
  baseSalary Float
  hra        Float?
  allowance  Float?
  deductions Float?
  tax        Float?
  netSalary  Float
  payPeriod  String
  status     String    @default("paid")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation("UserEmployeeSalary", fields: [userId], references: [id])
  payslips   Payslip[] @relation("UserPayslips")

  @@map("employee_salary")
}

model Payslip {
  id               Int            @id @default(autoincrement())
  employeeSalaryId Int
  period           String
  basicPay         Float
  hra              Float
  allowances       Float
  deductions       Float
  tax              Float
  netPay           Float
  workedDays       Int
  paidLeaveDays    Int
  unpaidLeaveDays  Int
  createdAt        DateTime       @default(now())
  employeeSalary   EmployeeSalary @relation("UserPayslips", fields: [employeeSalaryId], references: [id])

  @@unique([employeeSalaryId, period])
  @@map("payslip")
}

model CareerApplication {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String
  phone        String?
  position     String
  experience   String?
  currentJob   String?
  education    String?
  linkedinUrl  String?
  portfolioUrl String?
  coverLetter  String?  @db.Text
  resumeUrl    String?
  resumeName   String?
  status       String   @default("pending")
  source       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("careerapplication")
}

model JobOpening {
  id           Int      @id @default(autoincrement())
  title        String
  department   String
  location     String
  experience   String
  type         String   @default("Full Time")
  salary       String?
  description  String?  @db.Text
  requirements String?  @db.Text
  status       String   @default("active") // active | inactive | filled
  featured     Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("jobopening")
}

model BotPolicy {
  id        Int      @id @default(autoincrement())
  content   String   @db.LongText
  updatedAt DateTime @updatedAt

  @@map("botpolicy")
}
