generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model ChatConversation {
  id        Int      @id @default(autoincrement())
  visitorId String
  visitorName String?
  visitorEmail String?
  visitorPhone String?
  status    String   @default("active")
  priority  String   @default("normal")
  
  assignedTo   User? @relation("ChatAssignedTo", fields: [assignedToId], references: [id])
  assignedToId Int?
  
  tags      String?
  notes     String?
  rating    Int?
  feedback  String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  closedAt  DateTime?
  
  messages ChatMessage[]
  
  @@map("chatconversation")
}

model ChatMessage {
  id             Int      @id @default(autoincrement())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId Int
  
  content   String   @db.Text
  sender    String
  senderName String?
  
  type      String   @default("text")
  fileUrl   String?
  fileName  String?
  
  isRead    Boolean  @default(false)
  
  createdAt DateTime @default(now())
  
  @@map("chatmessage")
}

model User {
  id           Int     @id @default(autoincrement())
  name         String?
  email        String? @unique
  username     String  @unique
  passwordHash String

  status       String  @default("active")
  profileImage String?
  phone        String?
  whatsapp     String?
  title        String?
  department   String?
  bio          String?

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  roles        UserRole[]
  blogPosts    BlogPost[]
  contentItems ContentItem[]
  pages        Page[]
  leadsOwned   Lead[]        @relation("LeadOwner")

  ticketsOwned     Ticket[]        @relation("TicketOwner")
  ticketsRequested Ticket[]        @relation("TicketRequester")
  ticketComments   TicketComment[]

  adminLogs    AdminLog[]
  MediaItem    MediaItem[]
  LeadActivity LeadActivity[]

  chatsAssigned ChatConversation[] @relation("ChatAssignedTo")
  
  @@map("user")
}

model Role {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  displayName  String
  description  String?
  defaultRoute String?

  users       UserRole[]
  permissions RolePermission[]
  
  @@map("role")
}

model UserRole {
  id     Int  @id @default(autoincrement())
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId Int

  @@unique([userId, roleId])
  @@map("userrole")
}

model Permission {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  module      String?
  description String?

  roles RolePermission[]
  
  @@map("permission")
}

model RolePermission {
  id           Int        @id @default(autoincrement())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId       Int
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  permissionId Int

  @@unique([roleId, permissionId])
  @@map("rolepermission")
}

model BlogCategory {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts BlogPost[]
  
  @@map("blogcategory")
}

model BlogTag {
  id    Int           @id @default(autoincrement())
  name  String
  slug  String        @unique
  posts BlogPostTag[]
  
  @@map("blogtag")
}

model BlogPostTag {
  post   BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId Int
  tag    BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId  Int

  @@id([postId, tagId])
  @@map("blogposttag")
}

model BlogPost {
  id              Int      @id @default(autoincrement())
  type            String   @default("blog")
  title           String
  slug            String   @unique
  excerpt         String?
  contentJson     String?  @db.LongText
  status          String   @default("draft")
  featured        Boolean  @default(false)
  pinned          Boolean  @default(false)
  thumbnail       String?
  heroImage       String?
  readTimeMinutes Int?

  seoTitle        String?
  seoDescription  String?
  seoImage        String?

  publishedAt     DateTime?
  scheduledFor    DateTime?

  viewCount       Int      @default(0)
  likeCount       Int      @default(0)
  shareCount      Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  author   User?         @relation(fields: [authorId], references: [id])
  authorId Int?
  category BlogCategory? @relation(fields: [categoryId], references: [id])
  categoryId Int?

  tags      BlogPostTag[]
  feedbacks BlogFeedback[]
  
  @@map("blogpost")
}

model BlogFeedback {
  id        Int      @id @default(autoincrement())
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  
  @@map("blogfeedback")
}

model EGuide {
  id           Int     @id @default(autoincrement())
  slug         String  @unique
  title        String
  authorName   String?
  authorRole   String?
  coverImage   String?
  category     String?
  description  String?
  readTimeText String?

  summary      String?
  sectionsJson String? @db.LongText

  pdfUrl      String?
  status      String    @default("draft")
  publishedAt DateTime?

  seoTitle       String?
  seoDescription String?

  downloadCount Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("eguide")
}

model ContentItem {
  id          Int     @id @default(autoincrement())
  type        String
  title       String
  slug        String  @unique
  excerpt     String?
  contentJson String?
  industry    String?
  country     String?
  clientName  String?
  featured    Boolean @default(false)
  thumbnail   String?
  heroImage   String?

  seoTitle       String?
  seoDescription String?

  status      String    @default("draft")
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User? @relation(fields: [authorId], references: [id])
  authorId Int?

  downloadCount Int @default(0)
  
  @@map("contentitem")
}

model PortfolioProject {
  id          Int     @id @default(autoincrement())
  key         String  @unique
  type        String
  title       String
  category    String?
  description String?
  techStack   String?
  platforms   String?
  country     String?
  bgImage     String?
  bgColor     String?
  icon        String?
  phoneMockup String?
  badgesJson  String? @db.Text

  caseStudy   CaseStudy? @relation(fields: [caseStudyId], references: [id])
  caseStudyId Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("portfolioproject")
}

model CaseStudy {
  id          Int     @id @default(autoincrement())
  slug        String  @unique
  title       String
  subtitle    String?
  logo        String?
  heroBgImage String?
  heroCircle  String?
  heroMockups String?

  brandingJson     String?
  teamJson         String?
  clientJson       String?
  technologiesJson String?
  overviewJson     String?
  requirementsJson String?
  goalsJson        String?
  challengesJson   String?
  appScreensJson String? @db.LongText

  resultsJson      String?
  findYourAppJson  String?

  seoTitle       String?
  seoDescription String?

  portfolioProjects PortfolioProject[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("casestudy")
}

model Page {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  key       String
  type      String
  excerpt   String?  @db.LongText
  
  contentJson String? @db.LongText
  
  status    String   @default("draft")
  featured  Boolean  @default(false)
  
  seoTitle       String?
  seoDescription String? @db.LongText
  seoImage       String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  author     User?            @relation(fields: [authorId], references: [id])
  authorId   Int?
  navItems   NavigationItem[]
  
  @@index([type, status])
  @@index([slug])
  @@map("page")
}

model NavigationItem {
  id      Int     @id @default(autoincrement())
  label   String
  href    String
  group   String?
  order   Int     @default(0)
  visible Boolean @default(true)

  page   Page? @relation(fields: [pageId], references: [id])
  pageId Int?
  
  @@map("navigationitem")
}

model TeamMember {
  id          Int     @id @default(autoincrement())
  name        String
  title       String?
  department  String?
  photo       String?
  bio         String?
  linkedinUrl String?
  order       Int     @default(0)
  featured    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("teammember")
}

model EmployeeDirectoryItem {
  id         Int     @id @default(autoincrement())
  name       String
  title      String?
  department String?
  photo      String?
  email      String?
  phone      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("employeedirectoryitem")
}

model MediaItem {
  id        Int      @id @default(autoincrement())
  title     String?
  filePath  String
  thumbnail String?
  type      String
  category  String?
  tags      String?
  createdAt DateTime @default(now())

  uploadedBy   User? @relation(fields: [uploadedById], references: [id])
  uploadedById Int?
  
  @@map("mediaitem")
}

model SiteEvent {
  id                   Int      @id @default(autoincrement())
  title                String
  message              String
  ctaLabel             String?
  ctaHref              String?
  
  imageUrl             String?
  
  status               String   @default("draft")
  startsAt             DateTime?
  endsAt               DateTime?
  theme                String?
  showOnSlugs          String?
  triggerDelayMs       Int?
  triggerScrollPercent Int?
  maxShowsPerUser      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("siteevent")
}

model Lead {
  id       Int     @id @default(autoincrement())
  name     String
  email    String
  phone    String?
  whatsapp String?
  source   String?
  campaign String?
  message  String?
  status   String  @default("new")
  tags     String?

  formType String?
  formKey  String?

  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  budgetLabel    String?
  attachmentName String?
  ndaAccepted    Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User? @relation("LeadOwner", fields: [ownerId], references: [id])
  ownerId Int?

  activities LeadActivity[]
  tickets    Ticket[]
  
  @@map("lead")
}

model LeadActivity {
  id        Int      @id @default(autoincrement())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    Int
  type      String
  content   String?
  createdAt DateTime @default(now())

  createdBy   User? @relation(fields: [createdById], references: [id])
  createdById Int?
  
  @@map("leadactivity")
}

model Ticket {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  status      String  @default("open")
  priority    String  @default("medium")
  channel     String?
  tags        String?

  lead        Lead? @relation(fields: [leadId], references: [id])
  leadId      Int?
  requester   User? @relation("TicketRequester", fields: [requesterId], references: [id])
  requesterId Int?
  owner       User? @relation("TicketOwner", fields: [ownerId], references: [id])
  ownerId     Int?

  dueDate    DateTime?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments TicketComment[]
  
  @@map("ticket")
}

model TicketComment {
  id       Int    @id @default(autoincrement())
  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId Int

  type       String @default("note")
  visibility String @default("internal")
  content    String

  createdAt   DateTime @default(now())
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdById Int?
  
  @@map("ticketcomment")
}

model NewsletterList {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscribers NewsletterSubscription[]
  campaigns   EmailCampaign[]
  
  @@map("newsletterlist")
}

model NewsletterSubscription {
  id             Int       @id @default(autoincrement())
  email          String
  name           String?
  whatsapp       String?
  status         String    @default("active")
  source         String?
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  list   NewsletterList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId Int

  events NewsletterEvent[]

  @@unique([email, listId], name: "email_listId")
  @@map("newslettersubscription")
}

model NewsletterEvent {
  id        Int      @id @default(autoincrement())
  type      String
  metaJson  String?
  createdAt DateTime @default(now())

  subscription   NewsletterSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId Int
  
  @@map("newsletterevent")
}

model EmailCampaign {
  id           Int       @id @default(autoincrement())
  name         String
  subject      String
  preheader    String?
  slug         String    @unique
  status       String    @default("draft")
  contentHtml  String?
  contentText  String?
  providerId   String?
  scheduledFor DateTime?
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list   NewsletterList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId Int

  logs EmailDeliveryLog[]
  
  @@map("emailcampaign")
}

model EmailDeliveryLog {
  id         Int      @id @default(autoincrement())
  email      String
  event      String
  providerId String?
  metaJson   String?
  createdAt  DateTime @default(now())

  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId Int
  
  @@map("emaildeliverylog")
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  subject   String
  preview   String?
  bodyHtml  String?  @db.LongText
  bodyText  String?
  category  String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("emailtemplate")
}

model WhatsappIntegration {
  id          Int      @id @default(autoincrement())
  provider    String
  phoneNumber String
  name        String?
  status      String   @default("active")
  configJson  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("whatsappintegration")
}

model WhatsappTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  category  String?
  body      String   @db.LongText
  language  String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@map("whatsapptemplate")
}

model AdminLog {
  id     Int   @id @default(autoincrement())
  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  action     String
  entityType String
  entityId   Int?

  payloadBeforeJson String?
  payloadAfterJson  String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  
  @@map("adminlog")
}
