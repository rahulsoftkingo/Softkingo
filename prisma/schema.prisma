model SiteEvent {
  id                   Int      @id @default(autoincrement())
  title                String
  message              String
  ctaLabel             String?
  ctaHref              String?
  
  // NEW: Image field
  imageUrl             String?  // Banner/hero image URL
  
  status               String   @default("draft")
  startsAt             DateTime?
  endsAt               DateTime?
  theme                String?
  showOnSlugs          String?
  triggerDelayMs       Int?
  triggerScrollPercent Int?
