  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



//// 8) Operations: Leads + Tickets

model Lead {
  id       Int     @id @default(autoincrement())
  name     String
  email    String
  phone    String?
  whatsapp String?
  source   String?
  campaign String?
  message  String?
  status   String  @default("new")
  tags     String?

  // Forms meta
  formType String? // 'inquiry' | 'service' | 'eguide' | ...
  formKey  String? // e.g. 'home-inquiry', 'service-web-dev'

  // Marketing UTM
  utmSource   String?
  utmMedium   String?
  utmCampaign String?

  // Extra details
  budgetLabel    String?
  attachmentName String?
  ndaAccepted    Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User? @relation("LeadOwner", fields: [ownerId], references: [id])
  ownerId Int?

  activities LeadActivity[]
  tickets    Ticket[]
}

model LeadActivity {
  id        Int      @id @default(autoincrement())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    Int
  type      String
  content   String?
  createdAt DateTime @default(now())

  createdBy   User? @relation(fields: [createdById], references: [id])
  createdById Int?
}

model Ticket {
  id          Int     @id @default(autoincrement())
  title       String
  description String?
  status      String  @default("open") // open | in_progress | waiting | resolved | closed
  priority    String  @default("medium") // low | medium | high | urgent
  channel     String? // web | email | whatsapp | internal
  tags        String?

  // Linking
  lead        Lead? @relation(fields: [leadId], references: [id])
  leadId      Int?
  requester   User? @relation("TicketRequester", fields: [requesterId], references: [id])
  requesterId Int?
  owner       User? @relation("TicketOwner", fields: [ownerId], references: [id])
  ownerId     Int?

  dueDate    DateTime?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  comments TicketComment[]
}

model TicketComment {
  id       Int    @id @default(autoincrement())
  ticket   Ticket @relation(fields: [ticketId], references: [id])
  ticketId Int

  type       String @default("note") // note | reply | system
  visibility String @default("internal") // internal | public
  content    String

  createdAt   DateTime @default(now())
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdById Int?
}

//// 9) Newsletter

model NewsletterList {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscribers NewsletterSubscription[]
  campaigns   EmailCampaign[]
}

model NewsletterSubscription {
  id             Int       @id @default(autoincrement())
  email          String
  name           String?
  whatsapp       String?
  status         String    @default("active")
  source         String?
  subscribedAt   DateTime  @default(now())
  unsubscribedAt DateTime?

  list   NewsletterList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId Int

  events NewsletterEvent[]

  @@unique([email, listId], name: "email_listId")
}


model NewsletterEvent {
  id        Int      @id @default(autoincrement())
  type      String
  metaJson  String?
  createdAt DateTime @default(now())

  subscription   NewsletterSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  subscriptionId Int
}

model EmailCampaign {
  id           Int       @id @default(autoincrement())
  name         String
  subject      String
  preheader    String?
  slug         String    @unique
  status       String    @default("draft")
  contentHtml  String?
  contentText  String?
  providerId   String?
  scheduledFor DateTime?
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list   NewsletterList @relation(fields: [listId], references: [id], onDelete: Cascade)
  listId Int

  logs EmailDeliveryLog[]
}

model EmailDeliveryLog {
  id         Int      @id @default(autoincrement())
  email      String
  event      String
  providerId String?
  metaJson   String?
  createdAt  DateTime @default(now())

  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId Int
}
model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  subject   String
  preview   String?  // short preview text
  bodyHtml  String?  @db.LongText
  bodyText  String?
  category  String?  // 'welcome' | 'promo' | 'newsletter'
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


//// 10) Minimal WhatsApp integration (future-safe)

model WhatsappIntegration {
  id          Int      @id @default(autoincrement())
  provider    String
  phoneNumber String
  name        String?
  status      String   @default("active")
  configJson  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
model WhatsappTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  category  String?  // 'welcome' | 'promo' | 'support' etc.
  body      String   @db.LongText
  language  String?  // e.g. 'en'
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//// 11) Admin audit

model AdminLog {
  id     Int   @id @default(autoincrement())
  user   User? @relation(fields: [userId], references: [id])
  userId Int?

  action     String
  entityType String
  entityId   Int?

  payloadBeforeJson String?
  payloadAfterJson  String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
}